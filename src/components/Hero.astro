---
const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<header class="bg-white">
  <div class="max-w-6xl mx-auto px-4 py-16 md:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-center">
      <!-- Text content — left 60% -->
      <div class="lg:col-span-3">
        <!-- Promo badge -->
        <div class="inline-flex items-center gap-2 bg-accent/10 text-accent-dark border border-accent/30 rounded-full px-4 py-1.5 text-sm font-semibold mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z"/>
          </svg>
          Limited Time: 15% OFF All Repairs & Installations
        </div>

        <!-- H1 — value proposition -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-text leading-tight mb-4">
          Central Florida's Trusted Plumbing Experts
        </h1>

        <!-- Tagline — the subtle medieval nod -->
        <p class="text-lg md:text-xl text-text-secondary font-medium mb-8">
          The Plumbers in Shining Armor
        </p>

        <!-- Inline trust badges -->
        <div class="flex flex-wrap items-center gap-4 mb-10">
          <div class="flex items-center gap-1.5 text-sm font-medium text-text-secondary">
            <svg class="w-5 h-5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
            </svg>
            Licensed & Insured
          </div>
          <div class="flex items-center gap-1.5 text-sm font-medium text-text-secondary">
            <svg class="w-5 h-5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Same-Day Service
          </div>
          <div class="flex items-center gap-1.5 text-sm font-medium text-text-secondary">
            <svg class="w-5 h-5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            No Hidden Fees
          </div>
        </div>

        <!-- Dual CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={phone}
            class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Call Now: {phoneDisplay}
          </a>
          <a
            href="#contact"
            class="inline-flex items-center justify-center gap-2 border-2 border-primary text-primary hover:bg-primary hover:text-white font-bold text-lg px-8 py-4 rounded-lg transition-all duration-200"
          >
            Request a Quote
          </a>
        </div>
      </div>

      <!-- Visual block — right 40% -->
      <div class="hidden lg:block lg:col-span-2">
        <div class="relative aspect-square rounded-2xl bg-gradient-to-br from-primary via-primary-light to-primary overflow-hidden">
          <!-- Abstract plumbing shapes -->
          <div class="absolute inset-0 opacity-10">
            <div class="absolute top-8 right-8 w-32 h-32 border-4 border-white rounded-full"></div>
            <div class="absolute bottom-12 left-8 w-24 h-24 border-4 border-white rounded-full"></div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-40 h-1 bg-white rounded-full rotate-45"></div>
            <div class="absolute top-1/3 left-1/4 w-28 h-1 bg-white rounded-full -rotate-12"></div>
          </div>
          <!-- Center icon -->
          <div class="absolute inset-0 flex items-center justify-center">
            <svg class="w-24 h-24 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
