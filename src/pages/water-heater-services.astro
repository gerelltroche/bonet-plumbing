---
import Layout from "../layouts/Layout.astro";
import StickyNav from "../components/StickyNav.astro";
import Footer from "../components/Footer.astro";

const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<Layout
  title="Water Heater Repair & Installation | Bonet Plumbing"
  description="Water heater repair, replacement & tankless installation in Central Florida. Same-day service, upfront pricing. Licensed plumbers. Call 407-734-3968."
  breadcrumbs={[
    { name: "Home", url: "https://bonetplumbing.com/" },
    { name: "Water Heater Services" }
  ]}
>
  <StickyNav />
  <main>
    <section class="bg-gradient-to-b from-primary/[0.03] via-white to-white py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-extrabold text-text leading-tight mb-4">
          Water Heater Services in Central Florida
        </h1>
        <div class="w-16 h-1 bg-accent rounded-full mb-6"></div>
        <p class="text-lg text-text-secondary mb-8 max-w-2xl">
          Woke up to a cold shower? Hearing strange popping or rumbling from your water heater? Whether you need a quick repair or a full replacement, we'll get your hot water back fast — with same-day service and upfront pricing across Oviedo, Winter Springs, and East Orlando.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Water Heater Repair</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Strange noises, lukewarm water, or a puddle forming at the base? We diagnose and fix the problem fast — so you're not stuck taking cold showers.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Water Heater Replacement</h2>
            <p class="text-text-secondary text-sm leading-relaxed">If your water heater is over 8 years old and constantly breaking down, it's time for a new one. We handle same-day replacements and haul away your old unit.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Tankless Water Heaters</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Tired of running out of hot water? Upgrade to a tankless system for endless hot water, lower energy bills, and more space. We install Rinnai, Navien, and Rheem.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Maintenance & Flushing</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Central Florida's hard water builds up sediment that kills water heaters early. Regular flushing extends your unit's life and keeps your energy bills down.</p>
          </div>
        </div>

        <div class="bg-accent/10 border border-accent/20 rounded-lg p-6 mb-10">
          <p class="font-bold text-text mb-1">Save 15% on Water Heater Services</p>
          <p class="text-text-secondary text-sm">Mention this offer when you call. Available for Oviedo, Winter Springs & East Orlando residents.</p>
          <p class="text-text-secondary text-xs mt-2">Florida License #CFC1434246 · Licensed & Insured</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <!-- FAQ Section -->
        <div class="mt-16 pt-8 border-t border-border">
          <h2 class="text-2xl font-bold text-text mb-6">Frequently Asked Questions</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-text mb-2">How long does a water heater last?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">A traditional tank water heater typically lasts 8 to 12 years, while tankless models can last 15 to 20 years with proper maintenance. If yours is over 8 years old and needing frequent repairs, replacement is usually the better investment.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">Should I switch to a tankless water heater?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Tankless water heaters provide endless hot water, take up less space, and are more energy-efficient. They're ideal for families who run out of hot water frequently. We can assess your home's needs and recommend the best option for your situation.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">Why is my water heater making strange noises?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Popping, rumbling, or crackling sounds usually indicate sediment buildup at the bottom of the tank. Central Florida's hard water accelerates this problem. A professional flush can resolve the noise and improve efficiency.</p>
            </div>
          </div>
        </div>

        <nav class="mt-16 pt-8 border-t border-border" aria-label="Other services">
          <h2 class="text-lg font-bold text-text mb-4">Our Other Services</h2>
          <ul class="flex flex-wrap gap-3">
            <li><a href="/plumbing-repairs" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Plumbing Repairs</a></li>
            <li><a href="/drain-cleaning" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Drain Cleaning</a></li>
            <li><a href="/fixture-installation" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Fixture Installation</a></li>
            <li><a href="/repiping" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Repiping</a></li>
            <li><a href="/light-commercial-plumbing" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Light Commercial</a></li>
          </ul>
        </nav>
      </div>
    </section>
  </main>

  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long does a water heater last?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A traditional tank water heater typically lasts 8 to 12 years, while tankless models can last 15 to 20 years with proper maintenance. If yours is over 8 years old and needing frequent repairs, replacement is usually the better investment."
        }
      },
      {
        "@type": "Question",
        "name": "Should I switch to a tankless water heater?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tankless water heaters provide endless hot water, take up less space, and are more energy-efficient. They're ideal for families who run out of hot water frequently. We can assess your home's needs and recommend the best option for your situation."
        }
      },
      {
        "@type": "Question",
        "name": "Why is my water heater making strange noises?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Popping, rumbling, or crackling sounds usually indicate sediment buildup at the bottom of the tank. Central Florida's hard water accelerates this problem. A professional flush can resolve the noise and improve efficiency."
        }
      }
    ]
  })} />

  <Footer />
</Layout>
