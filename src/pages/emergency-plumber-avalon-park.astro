---
import Layout from "../layouts/Layout.astro";
import StickyNav from "../components/StickyNav.astro";
import Footer from "../components/Footer.astro";

const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<Layout
  title="Emergency Plumber Avalon Park | 24/7 Service | Bonet Plumbing"
  description="Emergency plumber in Avalon Park, FL 32828. Burst pipes, sewer backups, flooding & no hot water — fast response across every village. Call 407-734-3968."
  breadcrumbs={[
    { name: "Home", url: "https://bonetplumbing.com/" },
    { name: "Service Areas", url: "https://bonetplumbing.com/#service-areas" },
    { name: "Avalon Park Plumber", url: "https://bonetplumbing.com/avalon-park-plumber" },
    { name: "Emergency Plumber in Avalon Park" }
  ]}
>
  <StickyNav />
  <main>
    <section class="bg-gradient-to-b from-primary/[0.03] via-white to-white py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-extrabold text-text leading-tight mb-4">
          Emergency Plumber in Avalon Park
        </h1>
        <div class="w-16 h-1 bg-accent rounded-full mb-6"></div>
        <p class="text-lg text-text-secondary mb-4 max-w-2xl">
          Plumbing emergencies don't wait for business hours. Burst pipe flooding your garage? Sewage backing up into your home? Water heater leaking all over the floor? Call us now — we provide fast emergency plumbing response across every Avalon Park village in the 32828 zip code.
        </p>
        <p class="text-lg text-text-secondary mb-8 max-w-2xl">
          No overtime charges, no hidden fees. You'll get the same upfront pricing at 10 PM that you'd get at 10 AM.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Request Emergency Service
          </a>
        </div>

        <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">Emergencies We Handle in Avalon Park</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
          <div class="bg-surface border border-border rounded-xl p-6">
            <h3 class="text-xl font-bold text-text mb-3">Burst & Leaking Pipes</h3>
            <p class="text-text-secondary text-sm leading-relaxed">A burst pipe can dump hundreds of gallons into your home in minutes. We'll get to your Avalon Park home fast, shut off the water, and repair the damage before it gets worse.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h3 class="text-xl font-bold text-text mb-3">Sewer & Drain Backups</h3>
            <p class="text-text-secondary text-sm leading-relaxed">Sewage backing up through drains or toilets is a health hazard that can't wait until morning. We clear the blockage and restore drainage to prevent contamination and water damage in your home.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h3 class="text-xl font-bold text-text mb-3">Water Heater Failures</h3>
            <p class="text-text-secondary text-sm leading-relaxed">A leaking water heater can flood your garage or utility closet fast. Whether it needs a repair or same-day replacement, we'll restore your hot water and stop the flooding.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h3 class="text-xl font-bold text-text mb-3">Overflowing Toilets & Fixtures</h3>
            <p class="text-text-secondary text-sm leading-relaxed">An overflowing toilet or sink can cause significant water damage to floors and walls. We diagnose the cause — whether it's a clog, a failed valve, or a deeper sewer issue — and fix it on the spot.</p>
          </div>
        </div>

        <!-- What to Do -->
        <div class="bg-primary/5 border border-primary/10 rounded-xl p-6 mb-10">
          <h2 class="text-xl font-bold text-text mb-3">What to Do During a Plumbing Emergency</h2>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 bg-primary text-white rounded-full flex items-center justify-center shrink-0 mt-0.5 text-sm font-bold">1</span>
              <span class="text-text-secondary text-sm"><strong>Shut off the water.</strong> Your main shut-off valve is usually near the front of your home or in the garage. Turn it clockwise to stop all water flow and prevent further damage.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 bg-primary text-white rounded-full flex items-center justify-center shrink-0 mt-0.5 text-sm font-bold">2</span>
              <span class="text-text-secondary text-sm"><strong>Turn off the water heater.</strong> If your water heater is leaking or you've shut off the main water, turn off the water heater to prevent it from running dry and burning out the heating element.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 bg-primary text-white rounded-full flex items-center justify-center shrink-0 mt-0.5 text-sm font-bold">3</span>
              <span class="text-text-secondary text-sm"><strong>Call us at <a href={phone} class="text-accent font-bold hover:text-accent-light">{phoneDisplay}</a>.</strong> Describe what's happening and we'll dispatch a licensed plumber to your Avalon Park home as quickly as possible.</span>
            </li>
          </ul>
        </div>

        <div class="bg-accent/10 border border-accent/20 rounded-lg p-6 mb-10">
          <p class="font-bold text-text mb-1">No Overtime Charges — Ever</p>
          <p class="text-text-secondary text-sm">Nights, weekends, holidays — the price stays the same. Upfront pricing for all Avalon Park emergency calls.</p>
          <p class="text-text-secondary text-xs mt-2">Florida License #CFC1434246 · Licensed & Insured</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Request Emergency Service
          </a>
        </div>

        <!-- FAQ Section -->
        <div class="mt-16 pt-8 border-t border-border">
          <h2 class="text-2xl font-bold text-text mb-6">Emergency Plumbing FAQs — Avalon Park</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-text mb-2">How fast can you get to my Avalon Park home in an emergency?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">We prioritize emergency calls and dispatch to Avalon Park as quickly as possible. We'll give you an honest ETA when you call — not a vague "we'll be there sometime today" window.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">Do you charge extra for nights, weekends, or holidays?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">No. We believe plumbing emergencies are stressful enough without getting hit with overtime surcharges. Our pricing is the same whether you call at 2 PM on a Tuesday or 2 AM on Christmas.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">Where is the main water shut-off valve in my Avalon Park home?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">In most Avalon Park homes, the main shut-off valve is near the front of the house close to the water meter, or inside the garage. It's usually a ball valve with a lever handle. Turn it perpendicular to the pipe to shut off all water. Knowing where this is before an emergency can prevent thousands in water damage.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">What qualifies as a plumbing emergency?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">If water is actively flooding, sewage is backing up, you have no water at all, or a pipe has burst — that's an emergency. A slowly dripping faucet or minor leak can usually wait for a scheduled appointment. Not sure? Call us and we'll help you figure it out.</p>
            </div>
          </div>
        </div>

        <!-- Cross Navigation -->
        <nav class="mt-16 pt-8 border-t border-border" aria-label="Related services and areas">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            <div>
              <h2 class="text-lg font-bold text-text mb-4">Other Services in Avalon Park</h2>
              <ul class="flex flex-wrap gap-3">
                <li><a href="/drain-cleaning-avalon-park" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Drain Cleaning</a></li>
                <li><a href="/water-heater-services-avalon-park" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Water Heater Services</a></li>
                <li><a href="/repiping-avalon-park" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Repiping</a></li>
                <li><a href="/avalon-park-plumber" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">All Avalon Park Services</a></li>
              </ul>
            </div>
            <div>
              <h2 class="text-lg font-bold text-text mb-4">Nearby Service Areas</h2>
              <ul class="flex flex-wrap gap-3">
                <li><a href="/waterford-lakes-plumber" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Waterford Lakes</a></li>
                <li><a href="/alafaya-plumber" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Alafaya</a></li>
                <li><a href="/east-orlando-plumber" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">East Orlando</a></li>
              </ul>
            </div>
          </div>
        </nav>
      </div>
    </section>
  </main>

  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How fast can you get to my Avalon Park home in an emergency?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We prioritize emergency calls and dispatch to Avalon Park as quickly as possible. We'll give you an honest ETA when you call — not a vague 'we'll be there sometime today' window."
        }
      },
      {
        "@type": "Question",
        "name": "Do you charge extra for nights, weekends, or holidays?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. We believe plumbing emergencies are stressful enough without getting hit with overtime surcharges. Our pricing is the same whether you call at 2 PM on a Tuesday or 2 AM on Christmas."
        }
      },
      {
        "@type": "Question",
        "name": "Where is the main water shut-off valve in my Avalon Park home?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In most Avalon Park homes, the main shut-off valve is near the front of the house close to the water meter, or inside the garage. It's usually a ball valve with a lever handle. Turn it perpendicular to the pipe to shut off all water. Knowing where this is before an emergency can prevent thousands in water damage."
        }
      },
      {
        "@type": "Question",
        "name": "What qualifies as a plumbing emergency?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If water is actively flooding, sewage is backing up, you have no water at all, or a pipe has burst — that's an emergency. A slowly dripping faucet or minor leak can usually wait for a scheduled appointment. Not sure? Call us and we'll help you figure it out."
        }
      }
    ]
  })} />

  <!-- Service Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Emergency Plumber in Avalon Park",
    "provider": {
      "@type": "Plumber",
      "name": "Bonet Plumbing LLC",
      "telephone": "+14077343968",
      "url": "https://bonetplumbing.com"
    },
    "areaServed": {
      "@type": "Place",
      "name": "Avalon Park, Orlando, FL 32828"
    },
    "serviceType": "Emergency Plumbing",
    "description": "Emergency plumbing services in Avalon Park, FL. Burst pipes, sewer backups, water heater failures, and flooding — fast response across every village with no overtime charges."
  })} />

  <Footer />
</Layout>
