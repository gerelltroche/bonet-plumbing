  <!-- Service Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Repiping in Avalon Park",
    "provider": {
      "@type": "Plumber",
      "name": "Bonet Plumbing LLC",
      "telephone": "+14077343968",
      "url": "https://bonetplumbing.com"
    },
    "areaServed": {
      "@type": "Place",
      "name": "Avalon Park, Orlando, FL 32828"
    },
    "serviceType": "Repiping",
    "description": "Whole-home repiping and CPVC replacement in Avalon Park, FL. Pipe inspections, partial repiping, and full supply line replacement across every village."
  })} />

  <Footer />
</Layout>
