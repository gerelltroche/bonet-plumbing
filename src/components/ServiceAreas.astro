---
const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
const areas = [
  { name: "Oviedo", href: "/oviedo-plumber" },
  { name: "Winter Springs", href: "/winter-springs-plumber" },
  { name: "East Orlando", href: "/east-orlando-plumber" },
];
const moreAreas = [
  { name: "Casselberry", href: "/casselberry-plumber" },
  { name: "Altamonte Springs", href: "/altamonte-springs-plumber" },
  { name: "Longwood", href: "/longwood-plumber" },
  { name: "Lake Mary", href: "/lake-mary-plumber" },
  { name: "Sanford", href: "/sanford-plumber" },
  { name: "Winter Park", href: "/winter-park-plumber" },
  { name: "Maitland", href: "/maitland-plumber" },
  { name: "Alafaya", href: "/alafaya-plumber" },
  { name: "Waterford Lakes", href: "/waterford-lakes-plumber" },
  { name: "Avalon Park", href: "/avalon-park-plumber" },
  { name: "Chuluota", href: "/chuluota-plumber" },
  { name: "Geneva", href: "/geneva-plumber" },
  { name: "Goldenrod", href: "/goldenrod-plumber" },
  { name: "Fern Park", href: "/fern-park-plumber" },
  { name: "Union Park", href: "/union-park-plumber" },
  { name: "UCF Area", href: "/ucf-area-plumber" },
];
---

<section class="bg-primary py-16 md:py-20">
  <div class="max-w-5xl mx-auto px-4 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-10">Proudly Protecting Central Florida Homes</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      {areas.map((area) => (
        <a href={area.href} class="bg-white/10 backdrop-blur rounded-xl px-6 py-5 flex flex-col items-center gap-2 hover:bg-white/20 transition-colors">
          <svg class="w-6 h-6 text-accent-light shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
          </svg>
          <span class="text-xl font-semibold text-white">{area.name}</span>
        </a>
      ))}
    </div>

    <div class="flex flex-wrap justify-center gap-2 mb-10">
      {moreAreas.map((area) => (
        <a href={area.href} class="bg-white/5 hover:bg-white/15 text-white/70 hover:text-white text-sm font-medium px-4 py-2 rounded-full transition-colors">
          {area.name}
        </a>
      ))}
    </div>

    <a
      href={phone}
      class="inline-flex items-center gap-2 bg-white/15 hover:bg-white/25 text-white font-semibold px-6 py-3 rounded-lg transition-colors duration-200"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
      </svg>
      Need a plumber? Call {phoneDisplay}
    </a>
  </div>
</section>
