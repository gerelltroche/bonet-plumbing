---
import Layout from "../layouts/Layout.astro";
import StickyNav from "../components/StickyNav.astro";
import Footer from "../components/Footer.astro";

const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<Layout
  title="Drain Cleaning in Avalon Park | Bonet Plumbing LLC"
  description="Professional drain cleaning in Avalon Park, FL 32828. Kitchen drains, sewer lines, and clog removal across every village. Same-day service. Call 407-734-3968."
  breadcrumbs={[
    { name: "Home", url: "https://bonetplumbing.com/" },
    { name: "Service Areas", url: "https://bonetplumbing.com/#service-areas" },
    { name: "Avalon Park Plumber", url: "https://bonetplumbing.com/avalon-park-plumber" },
    { name: "Drain Cleaning in Avalon Park" }
  ]}
>
  <StickyNav />
  <main>
    <section class="bg-gradient-to-b from-primary/[0.03] via-white to-white py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-extrabold text-text leading-tight mb-4">
          Drain Cleaning in Avalon Park
        </h1>
        <div class="w-16 h-1 bg-accent rounded-full mb-6"></div>
        <p class="text-lg text-text-secondary mb-4 max-w-2xl">
          Slow drain getting worse? Water backing up in the shower or kitchen sink? Avalon Park homes deal with hard water mineral buildup, grease accumulation, and — in the older villages — tree root intrusion into sewer lines. Store-bought chemicals won't fix these problems and can damage your pipes.
        </p>
        <p class="text-lg text-text-secondary mb-8 max-w-2xl">
          We provide same-day drain cleaning across every Avalon Park village in the 32828 zip code — from Live Oak Village to River Haven to South Village. Upfront pricing, no overtime charges, and we don't leave until the water flows freely.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">Drain Services We Provide in Avalon Park</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
          <div class="bg-surface border border-border rounded-xl p-6">
            <h3 class="text-xl font-bold text-text mb-3">Kitchen Drain Cleaning</h3>
            <p class="text-text-secondary text-sm leading-relaxed">Grease, food scraps, and soap scum build up fast in Avalon Park kitchens — especially with hard water accelerating the problem. We clear the entire blockage, not just poke a hole through it.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h3 class="text-xl font-bold text-text mb-3">Bathroom Drain Cleaning</h3>
            <p class="text-text-secondary text-sm leading-relaxed">Hair, soap residue, and mineral deposits from Central Florida's hard water clog tub, shower, and sink drains. We clear the clog completely without damaging your fixtures or pipes.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h3 class="text-xl font-bold text-text mb-3">Sewer Line Cleaning</h3>
            <p class="text-text-secondary text-sm leading-relaxed">The mature oak and palm trees throughout Avalon Park's older villages can send roots into sewer lines, causing backups into your home. We clear root intrusions and sediment buildup before they cause sewage damage.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h3 class="text-xl font-bold text-text mb-3">Preventive Drain Maintenance</h3>
            <p class="text-text-secondary text-sm leading-relaxed">Don't wait for an emergency backup. Annual drain maintenance catches buildup early, saves you money on emergency calls, and keeps your plumbing system running smoothly year-round.</p>
          </div>
        </div>

        <!-- Common Avalon Park Problems -->
        <div class="bg-primary/5 border border-primary/10 rounded-xl p-6 mb-10">
          <h2 class="text-xl font-bold text-text mb-3">Common Drain Problems in Avalon Park Homes</h2>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z M12 15.75h.007v.008H12v-.008z"/></svg>
              <span class="text-text-secondary text-sm"><strong>Hard water mineral buildup</strong> — Central Florida's water is some of the hardest in the country, and it leaves calcium and lime deposits inside your drain pipes that narrow them over time</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z M12 15.75h.007v.008H12v-.008z"/></svg>
              <span class="text-text-secondary text-sm"><strong>Tree root intrusion</strong> — the mature landscaping in Avalon Park's older sections sends roots into sewer lines, causing slow drains and sewage backups</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z M12 15.75h.007v.008H12v-.008z"/></svg>
              <span class="text-text-secondary text-sm"><strong>Heavy rain flooding drains</strong> — Florida's rainy season puts extra load on drainage systems, overwhelming pipes that already have partial blockages</span>
            </li>
          </ul>
        </div>

        <div class="bg-accent/10 border border-accent/20 rounded-lg p-6 mb-10">
          <p class="font-bold text-text mb-1">Save 15% on Drain Cleaning</p>
          <p class="text-text-secondary text-sm">Mention this offer when you call. Available for Avalon Park residents in the 32828 zip code.</p>
          <p class="text-text-secondary text-xs mt-2">Florida License #CFC1434246 · Licensed & Insured</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <!-- FAQ Section -->
        <div class="mt-16 pt-8 border-t border-border">
          <h2 class="text-2xl font-bold text-text mb-6">Drain Cleaning FAQs — Avalon Park</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-text mb-2">Why do drains clog so often in Avalon Park?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Central Florida has some of the hardest water in the country. The calcium and mineral deposits in Avalon Park's water supply build up inside drain pipes over time, narrowing them and catching grease, hair, and debris that would otherwise flow through. Homes in older villages with mature trees also deal with root intrusion into sewer lines.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">Why shouldn't I use chemical drain cleaners?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Chemical drain cleaners can corrode your pipes over time — especially the CPVC plumbing common in Avalon Park homes built in the 2000s. They often only dissolve part of the clog, leaving the rest to build up again. Professional drain cleaning removes the entire blockage safely without pipe damage.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">How fast can you get to my Avalon Park home?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">We offer same-day drain cleaning service to every Avalon Park village. Most calls are handled the same day, and we'll give you a specific arrival window — no waiting around all day wondering when the plumber will show up.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">How often should I have my drains cleaned?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">We recommend annual preventive drain maintenance for most Avalon Park homes. If you have large trees near your sewer line, frequent slow drains, or older plumbing, every 6 months is a better investment to prevent emergency backups and costly repairs.</p>
            </div>
          </div>
        </div>

        <!-- Cross Navigation -->
        <nav class="mt-16 pt-8 border-t border-border" aria-label="Related services and areas">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            <div>
              <h2 class="text-lg font-bold text-text mb-4">Other Services in Avalon Park</h2>
              <ul class="flex flex-wrap gap-3">
                <li><a href="/water-heater-services-avalon-park" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Water Heater Services</a></li>
                <li><a href="/emergency-plumber-avalon-park" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Emergency Plumber</a></li>
                <li><a href="/repiping-avalon-park" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Repiping</a></li>
                <li><a href="/avalon-park-plumber" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">All Avalon Park Services</a></li>
              </ul>
            </div>
            <div>
              <h2 class="text-lg font-bold text-text mb-4">Nearby Service Areas</h2>
              <ul class="flex flex-wrap gap-3">
                <li><a href="/waterford-lakes-plumber" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Waterford Lakes</a></li>
                <li><a href="/alafaya-plumber" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Alafaya</a></li>
                <li><a href="/east-orlando-plumber" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">East Orlando</a></li>
              </ul>
            </div>
          </div>
        </nav>
      </div>
    </section>
  </main>

  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why do drains clog so often in Avalon Park?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Central Florida has some of the hardest water in the country. The calcium and mineral deposits in Avalon Park's water supply build up inside drain pipes over time, narrowing them and catching grease, hair, and debris that would otherwise flow through. Homes in older villages with mature trees also deal with root intrusion into sewer lines."
        }
      },
      {
        "@type": "Question",
        "name": "Why shouldn't I use chemical drain cleaners?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Chemical drain cleaners can corrode your pipes over time — especially the CPVC plumbing common in Avalon Park homes built in the 2000s. They often only dissolve part of the clog, leaving the rest to build up again. Professional drain cleaning removes the entire blockage safely without pipe damage."
        }
      },
      {
        "@type": "Question",
        "name": "How fast can you get to my Avalon Park home?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We offer same-day drain cleaning service to every Avalon Park village. Most calls are handled the same day, and we'll give you a specific arrival window — no waiting around all day wondering when the plumber will show up."
        }
      },
      {
        "@type": "Question",
        "name": "How often should I have my drains cleaned?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We recommend annual preventive drain maintenance for most Avalon Park homes. If you have large trees near your sewer line, frequent slow drains, or older plumbing, every 6 months is a better investment to prevent emergency backups and costly repairs."
        }
      }
    ]
  })} />

  <!-- Service Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Drain Cleaning in Avalon Park",
    "provider": {
      "@type": "Plumber",
      "name": "Bonet Plumbing LLC",
      "telephone": "+14077343968",
      "url": "https://bonetplumbing.com"
    },
    "areaServed": {
      "@type": "Place",
      "name": "Avalon Park, Orlando, FL 32828"
    },
    "serviceType": "Drain Cleaning",
    "description": "Professional drain cleaning services in Avalon Park, FL. Kitchen drains, bathroom drains, sewer line cleaning, and preventive maintenance across every village."
  })} />

  <Footer />
</Layout>
