---
import Layout from "../layouts/Layout.astro";
import StickyNav from "../components/StickyNav.astro";
import Footer from "../components/Footer.astro";

const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<Layout
  title="Avalon Park Plumber | Serving Every Village | Bonet Plumbing"
  description="Licensed plumber serving Avalon Park, FL 32828. Same-day drain cleaning, water heater repair, repiping & emergency plumbing across every village. Call 407-734-3968."
  breadcrumbs={[
    { name: "Home", url: "https://bonetplumbing.com/" },
    { name: "Service Areas", url: "https://bonetplumbing.com/#service-areas" },
    { name: "Avalon Park Plumber" }
  ]}
>
  <StickyNav />
  <main>
    <section class="bg-gradient-to-b from-primary/[0.03] via-white to-white py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-extrabold text-text leading-tight mb-4">
          Avalon Park Plumber — Serving Every Village
        </h1>
        <div class="w-16 h-1 bg-accent rounded-full mb-6"></div>
        <p class="text-lg text-text-secondary mb-4 max-w-2xl">
          From routine maintenance to emergency repairs, your Avalon Park home deserves a plumber who arrives fast and charges fairly. We serve every village in the 32828 zip code with same-day availability and upfront pricing — no guessing what the bill will be.
        </p>
        <p class="text-lg text-text-secondary mb-8 max-w-2xl">
          Whether you're in Live Oak Village, River Haven, South Village, or any other Avalon Park neighborhood — we know the plumbing in these homes. Most were built between 2003 and 2015, which means aging water heaters, CPVC pipes entering their failure window, and hard water that's been wearing on your plumbing for over a decade.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">Plumbing Services in Avalon Park</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
          <a href="/emergency-plumber-avalon-park" class="bg-surface border border-border rounded-xl p-5 hover:shadow-md transition-shadow group">
            <h3 class="text-lg font-bold text-text mb-2 group-hover:text-primary transition-colors">Emergency Plumber</h3>
            <p class="text-text-secondary text-sm">Burst pipe, sewer backup, or flooding? We respond fast to Avalon Park emergencies — no overtime charges.</p>
          </a>
          <a href="/water-heater-services-avalon-park" class="bg-surface border border-border rounded-xl p-5 hover:shadow-md transition-shadow group">
            <h3 class="text-lg font-bold text-text mb-2 group-hover:text-primary transition-colors">Water Heater Services</h3>
            <p class="text-text-secondary text-sm">No hot water? We repair, replace, and install tankless units — often the same day you call.</p>
          </a>
          <a href="/drain-cleaning-avalon-park" class="bg-surface border border-border rounded-xl p-5 hover:shadow-md transition-shadow group">
            <h3 class="text-lg font-bold text-text mb-2 group-hover:text-primary transition-colors">Drain Cleaning</h3>
            <p class="text-text-secondary text-sm">Slow drains or backed-up pipes? We clear clogs caused by hard water buildup and tree root intrusion.</p>
          </a>
          <a href="/fixture-installation" class="bg-surface border border-border rounded-xl p-5 hover:shadow-md transition-shadow group">
            <h3 class="text-lg font-bold text-text mb-2 group-hover:text-primary transition-colors">Fixture Installation</h3>
            <p class="text-text-secondary text-sm">New toilet, faucet, or sink? We install it right the first time — to code and leak-free.</p>
          </a>
          <a href="/repiping-avalon-park" class="bg-surface border border-border rounded-xl p-5 hover:shadow-md transition-shadow group">
            <h3 class="text-lg font-bold text-text mb-2 group-hover:text-primary transition-colors">Repiping</h3>
            <p class="text-text-secondary text-sm">CPVC pipes cracking? Many Avalon Park homes need repiping — we replace aging pipes with modern PEX.</p>
          </a>
          <a href="/light-commercial-plumbing" class="bg-surface border border-border rounded-xl p-5 hover:shadow-md transition-shadow group">
            <h3 class="text-lg font-bold text-text mb-2 group-hover:text-primary transition-colors">Light Commercial</h3>
            <p class="text-text-secondary text-sm">Plumbing for restaurants, offices, retail & rental properties — reliable service that keeps your business running.</p>
          </a>
        </div>

        <!-- Villages We Serve -->
        <div class="mb-12">
          <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">We Serve Every Avalon Park Village</h2>
          <p class="text-text-secondary mb-5 max-w-2xl">No matter which part of the 32828 zip code you live in, we provide same-day plumbing service to your door. We work in every Avalon Park village including:</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
            <span class="bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text-secondary text-center">Live Oak Village</span>
            <span class="bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text-secondary text-center">Northwest Village</span>
            <span class="bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text-secondary text-center">Parkside Landing</span>
            <span class="bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text-secondary text-center">River Haven</span>
            <span class="bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text-secondary text-center">South Village</span>
            <span class="bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text-secondary text-center">Town Center</span>
            <span class="bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text-secondary text-center">Villages at Timbercreek</span>
          </div>
        </div>

        <!-- Common Plumbing Problems -->
        <div class="mb-12">
          <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">Common Plumbing Problems in Avalon Park</h2>
          <p class="text-text-secondary mb-5 max-w-2xl">Avalon Park homes share a few plumbing challenges unique to this part of East Orlando. Knowing what to watch for can help you catch problems early — before they become emergencies.</p>
          <div class="space-y-4">
            <div class="bg-surface border border-border rounded-xl p-5">
              <h3 class="font-bold text-text mb-2">Hard Water Damage</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Central Florida has some of the hardest water in the country. In Avalon Park, the high calcium and mineral content in your water supply leaves deposits inside pipes, water heaters, and fixtures. Over time this narrows drain pipes, reduces water heater efficiency, and causes faucets to drip. If you see white crusty buildup around your faucets or showerhead, hard water is already affecting your plumbing.</p>
            </div>
            <div class="bg-surface border border-border rounded-xl p-5">
              <h3 class="font-bold text-text mb-2">Aging CPVC Pipes</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Most Avalon Park homes built between 2003 and 2012 used CPVC (chlorinated polyvinyl chloride) for supply lines. CPVC becomes brittle after 15-20 years under Florida conditions — the combination of high heat, humidity, and chlorine in the municipal water supply breaks it down. When CPVC fails, it cracks without warning, often causing sudden leaks inside walls. If your home is in one of the earlier-built villages, your pipes are in the window where failures start.</p>
            </div>
            <div class="bg-surface border border-border rounded-xl p-5">
              <h3 class="font-bold text-text mb-2">Water Heaters Failing Early</h3>
              <p class="text-text-secondary text-sm leading-relaxed">The same hard water that clogs your drains is also killing your water heater. Sediment settles at the bottom of the tank, makes the unit work harder, and eventually corrodes the lining. Builder-grade water heaters installed when Avalon Park homes were new are now 10-20 years old — well past their expected lifespan. If yours is making popping or rumbling sounds, it's full of sediment and on borrowed time.</p>
            </div>
            <div class="bg-surface border border-border rounded-xl p-5">
              <h3 class="font-bold text-text mb-2">Tree Root Intrusion</h3>
              <p class="text-text-secondary text-sm leading-relaxed">The mature oaks, palms, and landscaping throughout Avalon Park's older villages send roots toward sewer lines seeking moisture. Once roots find a joint or small crack, they grow into the pipe and cause slow drains, gurgling toilets, and eventually sewage backups. This is especially common in the earliest-built parts of Avalon Park where the trees have had 15-20 years to establish deep root systems.</p>
            </div>
          </div>
        </div>

        <!-- What You Get -->
        <div class="bg-primary/5 border border-primary/10 rounded-xl p-6 mb-10">
          <h2 class="text-xl font-bold text-text mb-3">Why Avalon Park Residents Call Us</h2>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              <span class="text-text-secondary text-sm"><strong>Licensed & insured</strong> — Florida License #CFC1434246, fully insured for your protection</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              <span class="text-text-secondary text-sm"><strong>Same-day service</strong> — we serve every Avalon Park village and most calls are handled the same day</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              <span class="text-text-secondary text-sm"><strong>Upfront pricing</strong> — you'll know the cost before we start, no hidden fees or surprise charges</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              <span class="text-text-secondary text-sm"><strong>No overtime charges</strong> — emergency calls at night and on weekends cost the same as during business hours</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              <span class="text-text-secondary text-sm"><strong>Save 15%</strong> on all repairs & installations — available to Avalon Park residents in the 32828 zip code</span>
            </li>
          </ul>
        </div>

        <div class="bg-accent/10 border border-accent/20 rounded-lg p-6 mb-10">
          <p class="font-bold text-text mb-1">Save 15% on Plumbing Services</p>
          <p class="text-text-secondary text-sm">Mention this offer when you call. Available for all Avalon Park residents in the 32828 zip code.</p>
          <p class="text-text-secondary text-xs mt-2">Florida License #CFC1434246 · Licensed & Insured</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <!-- FAQ Section -->
        <div class="pt-8 border-t border-border">
          <h2 class="text-2xl font-bold text-text mb-6">Plumbing FAQs — Avalon Park</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-text mb-2">What plumbing problems are common in Avalon Park homes?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">The most common issues we see in Avalon Park are clogged drains from hard water mineral buildup, failing water heaters due to sediment accumulation, CPVC pipe cracks in homes built in the 2000s, and sewer line blockages from tree root intrusion in the older villages. All of these are related to the age of the homes and Central Florida's water quality.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">How fast can a plumber get to my Avalon Park home?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">We offer same-day plumbing service to every Avalon Park village. When you call, we'll give you a specific arrival window — not a vague "sometime today" estimate. For emergencies like burst pipes or sewer backups, we prioritize fast dispatch.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">Do you charge more for emergency or after-hours calls?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">No. We don't charge overtime, after-hours, or weekend surcharges. Plumbing emergencies are stressful enough — our pricing stays the same whether you call at 2 PM or 2 AM.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">Does my Avalon Park home have CPVC pipes?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Most Avalon Park homes built between 2003 and 2012 used CPVC for supply lines. You can check by looking at exposed pipes in your garage or under sinks — CPVC is a light yellow or cream-colored plastic pipe. After 15-20 years in Florida conditions, CPVC becomes brittle and prone to cracking. If you're not sure what you have, we can inspect and let you know.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">Is the hard water in Avalon Park really that bad?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Central Florida consistently ranks among the hardest water in the country. In Avalon Park's 32828 zip code, the high mineral content causes calcium deposits inside your pipes, shortens water heater life, and clogs drains faster than you'd see in areas with softer water. Annual drain maintenance and water heater flushing go a long way toward protecting your plumbing.</p>
            </div>
          </div>
        </div>

        <!-- Cross Navigation -->
        <nav class="mt-16 pt-8 border-t border-border" aria-label="Related services and areas">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            <div>
              <h2 class="text-lg font-bold text-text mb-4">Avalon Park Plumbing Services</h2>
              <ul class="flex flex-wrap gap-3">
                <li><a href="/drain-cleaning-avalon-park" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Drain Cleaning</a></li>
                <li><a href="/water-heater-services-avalon-park" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Water Heater Services</a></li>
                <li><a href="/emergency-plumber-avalon-park" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Emergency Plumber</a></li>
                <li><a href="/repiping-avalon-park" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Repiping</a></li>
              </ul>
            </div>
            <div>
              <h2 class="text-lg font-bold text-text mb-4">Nearby Service Areas</h2>
              <ul class="flex flex-wrap gap-3">
                <li><a href="/waterford-lakes-plumber" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Waterford Lakes</a></li>
                <li><a href="/alafaya-plumber" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Alafaya</a></li>
                <li><a href="/east-orlando-plumber" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">East Orlando</a></li>
                <li><a href="/union-park-plumber" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Union Park</a></li>
              </ul>
            </div>
          </div>
        </nav>
      </div>
    </section>
  </main>

  <!-- FAQPage Schema -->
