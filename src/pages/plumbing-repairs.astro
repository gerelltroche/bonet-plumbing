---
import Layout from "../layouts/Layout.astro";
import StickyNav from "../components/StickyNav.astro";
import Footer from "../components/Footer.astro";

const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<Layout
  title="Plumbing Repairs | Bonet Plumbing LLC"
  description="Expert plumbing repair services in Central Florida. Leak detection, pipe repair, slab leaks & emergency plumbing. Licensed & insured. Call 407-734-3968."
  breadcrumbs={[
    { name: "Home", url: "https://bonetplumbing.com/" },
    { name: "Plumbing Repairs" }
  ]}
>
  <StickyNav />
  <main>
    <section class="bg-gradient-to-b from-primary/[0.03] via-white to-white py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-extrabold text-text leading-tight mb-4">
          Plumbing Repairs in Central Florida
        </h1>
        <div class="w-16 h-1 bg-accent rounded-full mb-6"></div>
        <p class="text-lg text-text-secondary mb-8 max-w-2xl">
          Dripping faucet keeping you up at night? Water stain spreading on your ceiling? Whether it's a minor leak or a major pipe emergency, you'll get a licensed plumber at your door fast — with upfront pricing and same-day service across Oviedo, Winter Springs, and East Orlando.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Leak Detection & Repair</h2>
            <p class="text-text-secondary text-sm leading-relaxed">A hidden leak can cost you hundreds in water bills and cause serious structural damage. We'll find it, fix it, and make sure it stays fixed — before it becomes a bigger problem.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Pipe Repair & Replacement</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Corroded, burst, or aging pipes? We repair and replace galvanized, copper, PVC, and PEX piping so your water pressure and quality are restored.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Slab Leak Repair</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Noticing warm spots on your floor or a spike in your water bill? These are signs of a slab leak. We detect and repair them with minimal disruption to your home.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Emergency Plumbing</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Burst pipe at 7 AM? Overflowing toilet before guests arrive? We offer same-day emergency service — call now and we'll be there fast.</p>
          </div>
        </div>

        <div class="bg-accent/10 border border-accent/20 rounded-lg p-6 mb-10">
          <p class="font-bold text-text mb-1">Save 15% on Any Plumbing Repair</p>
          <p class="text-text-secondary text-sm">Mention this offer when you call. Available for Oviedo, Winter Springs & East Orlando residents.</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <!-- FAQ Section -->
        <div class="mt-16 pt-8 border-t border-border">
          <h2 class="text-2xl font-bold text-text mb-6">Frequently Asked Questions</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-text mb-2">How quickly can you get here for an emergency repair?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">We offer same-day service throughout Oviedo, Winter Springs, and East Orlando. In most cases, a licensed plumber can be at your door within a few hours of your call.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">Do you provide free estimates for plumbing repairs?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Yes. We provide free, no-obligation estimates with upfront pricing before any work begins. You'll know the full cost before we start — no surprises.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">How do I know if I have a slab leak?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Common signs include unexplained increases in your water bill, warm spots on the floor, the sound of running water when all fixtures are off, and cracks in walls or flooring. We use professional detection equipment to locate slab leaks with minimal disruption.</p>
            </div>
          </div>
        </div>

        <nav class="mt-16 pt-8 border-t border-border" aria-label="Other services">
          <h2 class="text-lg font-bold text-text mb-4">Our Other Services</h2>
          <ul class="flex flex-wrap gap-3">
            <li><a href="/water-heater-services" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Water Heater Services</a></li>
            <li><a href="/drain-cleaning" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Drain Cleaning</a></li>
            <li><a href="/fixture-installation" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Fixture Installation</a></li>
          </ul>
        </nav>
      </div>
    </section>
  </main>

  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How quickly can you get here for an emergency repair?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We offer same-day service throughout Oviedo, Winter Springs, and East Orlando. In most cases, a licensed plumber can be at your door within a few hours of your call."
        }
      },
      {
        "@type": "Question",
        "name": "Do you provide free estimates for plumbing repairs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We provide free, no-obligation estimates with upfront pricing before any work begins. You'll know the full cost before we start — no surprises."
        }
      },
      {
        "@type": "Question",
        "name": "How do I know if I have a slab leak?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Common signs include unexplained increases in your water bill, warm spots on the floor, the sound of running water when all fixtures are off, and cracks in walls or flooring. We use professional detection equipment to locate slab leaks with minimal disruption."
        }
      }
    ]
  })} />

  <Footer />
</Layout>
