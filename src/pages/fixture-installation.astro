---
import Layout from "../layouts/Layout.astro";
import StickyNav from "../components/StickyNav.astro";
import Footer from "../components/Footer.astro";

const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<Layout
  title="Fixture Installation | Bonet Plumbing LLC"
  description="Professional plumbing fixture installation — toilets, faucets, sinks, showers & bathroom remodels. Licensed Central Florida plumbers. Call 407-734-3968."
  breadcrumbs={[
    { name: "Home", url: "https://bonetplumbing.com/" },
    { name: "Fixture Installation" }
  ]}
>
  <StickyNav />
  <main>
    <section class="bg-gradient-to-b from-primary/[0.03] via-white to-white py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-extrabold text-text leading-tight mb-4">
          Fixture Installation in Central Florida
        </h1>
        <div class="w-16 h-1 bg-accent rounded-full mb-6"></div>
        <p class="text-lg text-text-secondary mb-8 max-w-2xl">
          Ready for that new kitchen faucet or bathroom upgrade? Whether you bought your own fixtures or need help choosing, we'll install everything to code — with clean, careful work and no leaks. Serving Oviedo, Winter Springs, and East Orlando.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Toilet Installation</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Running toilet driving up your water bill? Upgrading to a low-flow model? We handle removal of the old unit, proper installation, and leak testing — done right the first time.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Faucet & Sink Installation</h2>
            <p class="text-text-secondary text-sm leading-relaxed">A new faucet or sink instantly updates your kitchen or bathroom. We install all types — undermount, drop-in, vessel — with proper connections and zero leaks.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Garbage Disposal Installation</h2>
            <p class="text-text-secondary text-sm leading-relaxed">We install and replace all major brands. Proper installation means no leaks, no jams, and no electrical issues down the road.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Shower Installation</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Upgrading your shower head, replacing a shower valve, or installing a new shower system? We handle the plumbing so everything works perfectly from day one.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Bathroom Remodel Plumbing</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Renovating your bathroom? We handle all the plumbing — rough-in, fixture placement, shower valves, and final connections to bring your vision together.</p>
          </div>
        </div>

        <div class="bg-accent/10 border border-accent/20 rounded-lg p-6 mb-10">
          <p class="font-bold text-text mb-1">Save 15% on All Fixture Installations</p>
          <p class="text-text-secondary text-sm">Mention this offer when you call. Available for Oviedo, Winter Springs & East Orlando residents.</p>
          <p class="text-text-secondary text-xs mt-2">Florida License #CFC1434246 · Licensed & Insured</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <!-- FAQ Section -->
        <div class="mt-16 pt-8 border-t border-border">
          <h2 class="text-2xl font-bold text-text mb-6">Frequently Asked Questions</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-text mb-2">Can I install a new faucet or toilet myself?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">While some fixtures appear simple to install, improper installation can cause leaks, water damage, and code violations. A licensed plumber ensures proper connections, leak-free installation, and compliance with Florida building codes.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">Can I buy my own fixtures and have you install them?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Absolutely. Many of our customers purchase their own faucets, toilets, and sinks. We'll install whatever you choose — just make sure it's compatible with your existing plumbing, or we can advise you before you buy.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">How long does a fixture installation take?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Most single-fixture installations (toilet, faucet, or sink) take 1 to 2 hours. Bathroom remodel plumbing with multiple fixtures may take a full day depending on the scope of work.</p>
            </div>
          </div>
        </div>

        <nav class="mt-16 pt-8 border-t border-border" aria-label="Other services">
          <h2 class="text-lg font-bold text-text mb-4">Our Other Services</h2>
          <ul class="flex flex-wrap gap-3">
            <li><a href="/plumbing-repairs" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Plumbing Repairs</a></li>
            <li><a href="/water-heater-services" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Water Heater Services</a></li>
            <li><a href="/drain-cleaning" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Drain Cleaning</a></li>
            <li><a href="/repiping" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Repiping</a></li>
            <li><a href="/light-commercial-plumbing" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Light Commercial</a></li>
          </ul>
        </nav>
      </div>
    </section>
  </main>

  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Can I install a new faucet or toilet myself?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "While some fixtures appear simple to install, improper installation can cause leaks, water damage, and code violations. A licensed plumber ensures proper connections, leak-free installation, and compliance with Florida building codes."
        }
      },
      {
        "@type": "Question",
        "name": "Can I buy my own fixtures and have you install them?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. Many of our customers purchase their own faucets, toilets, and sinks. We'll install whatever you choose — just make sure it's compatible with your existing plumbing, or we can advise you before you buy."
        }
      },
      {
        "@type": "Question",
        "name": "How long does a fixture installation take?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most single-fixture installations (toilet, faucet, or sink) take 1 to 2 hours. Bathroom remodel plumbing with multiple fixtures may take a full day depending on the scope of work."
        }
      }
    ]
  })} />

  <Footer />
</Layout>
