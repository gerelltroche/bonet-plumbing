---
import Layout from "../layouts/Layout.astro";
import StickyNav from "../components/StickyNav.astro";
import Footer from "../components/Footer.astro";

const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<Layout
  title="Drain Cleaning Services | Bonet Plumbing LLC"
  description="Professional drain cleaning and sewer line services in Central Florida. Clog removal, sewer cleaning & preventive maintenance. Call 407-734-3968."
  breadcrumbs={[
    { name: "Home", url: "https://bonetplumbing.com/" },
    { name: "Drain Cleaning" }
  ]}
>
  <StickyNav />
  <main>
    <section class="bg-gradient-to-b from-primary/[0.03] via-white to-white py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-extrabold text-text leading-tight mb-4">
          Drain Cleaning in Central Florida
        </h1>
        <div class="w-16 h-1 bg-accent rounded-full mb-6"></div>
        <p class="text-lg text-text-secondary mb-8 max-w-2xl">
          Sink barely draining? Shower filling up around your feet? Bad smell coming from the pipes? These are signs you need professional drain cleaning — not a bottle of store-bought chemicals. We clear stubborn clogs and restore full drainage across Oviedo, Winter Springs, and East Orlando.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Kitchen Drain Cleaning</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Grease, food buildup, and soap scum will eventually choke your kitchen drain. We clear the blockage completely so water flows freely — not just a temporary fix.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Bathroom Drain Cleaning</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Hair, soap residue, and mineral deposits are the usual suspects. We clear tub, shower, and sink clogs without damaging your fixtures or pipes.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Sewer Line Cleaning</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Tree root intrusion and sediment buildup can cause sewage backups into your home. We provide professional sewer cleaning to prevent costly damage.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Preventive Maintenance</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Don't wait for an emergency clog. Regular drain maintenance saves you money and keeps your plumbing system running smoothly year-round.</p>
          </div>
        </div>

        <div class="bg-accent/10 border border-accent/20 rounded-lg p-6 mb-10">
          <p class="font-bold text-text mb-1">Save 15% on Drain Cleaning</p>
          <p class="text-text-secondary text-sm">Mention this offer when you call. Available for Oviedo, Winter Springs & East Orlando residents.</p>
          <p class="text-text-secondary text-xs mt-2">Florida License #CFC1434246 · Licensed & Insured</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <!-- FAQ Section -->
        <div class="mt-16 pt-8 border-t border-border">
          <h2 class="text-2xl font-bold text-text mb-6">Frequently Asked Questions</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-text mb-2">Why shouldn't I use chemical drain cleaners?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Chemical drain cleaners can corrode your pipes over time, especially older plumbing. They often only dissolve part of the clog, leaving the rest to build up again. Professional drain cleaning removes the entire blockage safely.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">How often should I have my drains professionally cleaned?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">We recommend annual preventive drain maintenance for most homes. If you have older plumbing, trees near your sewer line, or frequent slow drains, every 6 months may be better to prevent emergency backups.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">What causes recurring drain clogs?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Recurring clogs usually indicate a deeper issue — tree root intrusion in the sewer line, pipe corrosion, or a bellied (sagging) pipe section. A professional inspection can identify the root cause and prevent repeat problems.</p>
            </div>
          </div>
        </div>

        <nav class="mt-16 pt-8 border-t border-border" aria-label="Other services">
          <h2 class="text-lg font-bold text-text mb-4">Our Other Services</h2>
          <ul class="flex flex-wrap gap-3">
            <li><a href="/plumbing-repairs" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Plumbing Repairs</a></li>
            <li><a href="/water-heater-services" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Water Heater Services</a></li>
            <li><a href="/fixture-installation" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Fixture Installation</a></li>
            <li><a href="/repiping" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Repiping</a></li>
            <li><a href="/light-commercial-plumbing" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Light Commercial</a></li>
          </ul>
        </nav>
      </div>
    </section>
  </main>

  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why shouldn't I use chemical drain cleaners?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Chemical drain cleaners can corrode your pipes over time, especially older plumbing. They often only dissolve part of the clog, leaving the rest to build up again. Professional drain cleaning removes the entire blockage safely."
        }
      },
      {
        "@type": "Question",
        "name": "How often should I have my drains professionally cleaned?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We recommend annual preventive drain maintenance for most homes. If you have older plumbing, trees near your sewer line, or frequent slow drains, every 6 months may be better to prevent emergency backups."
        }
      },
      {
        "@type": "Question",
        "name": "What causes recurring drain clogs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Recurring clogs usually indicate a deeper issue — tree root intrusion in the sewer line, pipe corrosion, or a bellied (sagging) pipe section. A professional inspection can identify the root cause and prevent repeat problems."
        }
      }
    ]
  })} />

  <Footer />
</Layout>
