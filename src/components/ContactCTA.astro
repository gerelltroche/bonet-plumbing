---
const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<section id="contact" class="bg-white py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Left column — persuasion -->
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-text mb-3">Ready to Call in the Cavalry?</h2>
        <div class="w-16 h-1 bg-accent rounded-full mb-6"></div>

        <!-- Promo reminder -->
        <div class="bg-accent/10 border border-accent/20 rounded-lg p-5 mb-8">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z"/>
            </svg>
            <div>
              <p class="font-bold text-text">15% OFF All Repairs & Installations</p>
              <p class="text-text-secondary text-sm mt-1">Limited-time offer for Oviedo, Winter Springs & East Orlando</p>
            </div>
          </div>
        </div>

        <!-- Benefit bullets -->
        <ul class="space-y-4 mb-10">
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
            <span class="text-text-secondary">Free estimates — no obligations</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
            <span class="text-text-secondary">Same-day rescue missions available</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
            <span class="text-text-secondary">Our knight's promise: satisfaction guaranteed</span>
          </li>
        </ul>

        <!-- Owner card -->
        <div class="flex items-center gap-4 bg-primary/5 border border-primary/10 rounded-lg p-4 mb-10">
          <img src="/Headshot.jpeg" alt="Leo Bonet, Owner of Bonet Plumbing" class="w-20 h-20 rounded-full object-cover object-[center_20%] shadow-md ring-2 ring-primary/15" />
          <div>
            <p class="font-bold text-text">Leo Bonet</p>
            <p class="text-sm text-text-secondary">Owner & Licensed Plumber</p>
            <p class="text-xs text-text-secondary/70">License #CFC1434246</p>
          </div>
        </div>

        <!-- Phone CTA -->
        <p class="text-text-secondary text-sm mb-3">Prefer to call?</p>
        <a
          href={phone}
          class="inline-flex items-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
          Call Now: {phoneDisplay}
        </a>
      </div>

      <!-- Right column — form -->
      <div id="form-container" class="bg-surface border border-border rounded-xl shadow-lg p-6 md:p-8">
        <h3 class="text-xl font-bold text-text mb-6">Request a Quote</h3>

        <form
          id="contact-form"
          name="contact"
          method="POST"
          action="/success"
          netlify
          netlify-honeypot="bot-field"
        >
          <!-- Honeypot for spam prevention -->
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden" aria-hidden="true">
            <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>

          <div class="space-y-5">
            <!-- Name -->
            <div>
              <label for="name" class="block text-sm font-semibold text-text mb-1.5">
                Name <span class="text-red-600">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your full name"
                class="w-full px-4 py-3 border border-border rounded-lg bg-background text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-colors"
              />
            </div>

            <!-- Phone -->
            <div>
              <label for="phone" class="block text-sm font-semibold text-text mb-1.5">
                Phone <span class="text-red-600">*</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                inputmode="tel"
                placeholder="(407) 555-1234"
                class="w-full px-4 py-3 border border-border rounded-lg bg-background text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-colors"
              />
            </div>

            <!-- Service Needed -->
            <div>
              <label for="service" class="block text-sm font-semibold text-text mb-1.5">
                Service Needed <span class="text-red-600">*</span>
              </label>
              <select
                id="service"
                name="service"
                required
                class="w-full px-4 py-3 border border-border rounded-lg bg-background text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-colors cursor-pointer"
              >
                <option value="" disabled selected>Select a service</option>
                <option value="plumbing-repair">Plumbing Repair</option>
                <option value="water-heater">Water Heater</option>
                <option value="drain-cleaning">Drain Cleaning</option>
                <option value="fixture-installation">Fixture Installation</option>
                <option value="other">Other</option>
              </select>
            </div>

            <!-- Email (optional) -->
            <div>
              <label for="email" class="block text-sm font-semibold text-text mb-1.5">
                Email <span class="text-text-muted text-xs font-normal">(optional)</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="your@email.com"
                class="w-full px-4 py-3 border border-border rounded-lg bg-background text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-colors"
              />
            </div>

            <!-- Message (optional) -->
            <div>
              <label for="message" class="block text-sm font-semibold text-text mb-1.5">
                Anything else we should know? <span class="text-text-muted text-xs font-normal">(optional)</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="3"
                placeholder="Describe your plumbing issue..."
                class="w-full px-4 py-3 border border-border rounded-lg bg-background text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-colors resize-y"
              ></textarea>
            </div>

            <!-- Submit button -->
            <button
              type="submit"
              id="submit-btn"
              class="w-full bg-accent hover:bg-accent-light text-white font-bold text-lg py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg cursor-pointer"
            >
              Request Service
            </button>

            <!-- Response time -->
            <p class="text-text-muted text-xs text-center">
              We typically respond within 1 hour during business hours
            </p>
          </div>
        </form>

      </div>
    </div>
  </div>
</section>
