---
import Layout from "../layouts/Layout.astro";
import StickyNav from "../components/StickyNav.astro";
import Footer from "../components/Footer.astro";

const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<Layout
  title="Light Commercial Plumbing | Bonet Plumbing LLC"
  description="Light commercial plumbing services in Central Florida. Restaurants, offices, retail & small businesses. Licensed & insured. Call 407-734-3968."
  breadcrumbs={[
    { name: "Home", url: "https://bonetplumbing.com/" },
    { name: "Light Commercial Plumbing" }
  ]}
>
  <StickyNav />
  <main>
    <section class="bg-gradient-to-b from-primary/[0.03] via-white to-white py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-extrabold text-text leading-tight mb-4">
          Light Commercial Plumbing in Central Florida
        </h1>
        <div class="w-16 h-1 bg-accent rounded-full mb-6"></div>
        <p class="text-lg text-text-secondary mb-8 max-w-2xl">
          Running a business means plumbing problems can't wait. A backed-up drain in your restaurant kitchen or a leaking pipe in your office suite costs you money every minute it's not fixed. We provide the same fast, honest service to small businesses that we bring to homeowners — with upfront pricing and minimal disruption to your operations.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Restaurant & Food Service Plumbing</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Grease trap issues, commercial drain cleaning, dishwasher hookups, and gas line work for commercial kitchens. We help you stay up to code and keep your kitchen running.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Office & Retail Plumbing</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Restroom repairs, water heater maintenance, fixture upgrades, and leak repairs for offices, retail spaces, and small commercial buildings.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Property Management Plumbing</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Managing rental properties or small apartment buildings? We offer fast, reliable service for tenant plumbing issues — leaks, clogs, water heaters, and fixture replacements.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Tenant Build-Outs & Renovations</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Moving into a new commercial space? We handle plumbing rough-ins, fixture installation, and code compliance for tenant improvements and small renovations.</p>
          </div>
        </div>

        <div class="bg-accent/10 border border-accent/20 rounded-lg p-6 mb-10">
          <p class="font-bold text-text mb-1">Save 15% on Light Commercial Plumbing</p>
          <p class="text-text-secondary text-sm">Mention this offer when you call. Available for businesses in Oviedo, Winter Springs & East Orlando.</p>
          <p class="text-text-secondary text-xs mt-2">Florida License #CFC1434246 · Licensed & Insured</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <!-- FAQ Section -->
        <div class="mt-16 pt-8 border-t border-border">
          <h2 class="text-2xl font-bold text-text mb-6">Frequently Asked Questions</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-text mb-2">What types of commercial properties do you service?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">We handle light commercial work for restaurants, retail stores, offices, small medical and dental practices, salons, rental properties, and small apartment buildings. For large-scale commercial or industrial projects, we can refer you to a commercial specialist.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">Can you work around our business hours?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Yes. We understand that plumbing work during business hours means lost revenue. We offer flexible scheduling including early mornings, evenings, and weekends to minimize disruption to your operations.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">Do you handle grease trap maintenance?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Yes. We service grease traps for restaurants and food service businesses, including cleaning, repair, and ensuring compliance with local health codes. Regular grease trap maintenance prevents costly backups and code violations.</p>
            </div>
          </div>
        </div>

        <nav class="mt-16 pt-8 border-t border-border" aria-label="Other services">
          <h2 class="text-lg font-bold text-text mb-4">Our Other Services</h2>
          <ul class="flex flex-wrap gap-3">
            <li><a href="/plumbing-repairs" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Plumbing Repairs</a></li>
            <li><a href="/water-heater-services" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Water Heater Services</a></li>
            <li><a href="/drain-cleaning" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Drain Cleaning</a></li>
            <li><a href="/fixture-installation" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Fixture Installation</a></li>
            <li><a href="/repiping" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Repiping</a></li>
          </ul>
        </nav>
      </div>
    </section>
  </main>

  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What types of commercial properties do you service?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We handle light commercial work for restaurants, retail stores, offices, small medical and dental practices, salons, rental properties, and small apartment buildings. For large-scale commercial or industrial projects, we can refer you to a commercial specialist."
        }
      },
      {
        "@type": "Question",
        "name": "Can you work around our business hours?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We understand that plumbing work during business hours means lost revenue. We offer flexible scheduling including early mornings, evenings, and weekends to minimize disruption to your operations."
        }
      },
      {
        "@type": "Question",
        "name": "Do you handle grease trap maintenance?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We service grease traps for restaurants and food service businesses, including cleaning, repair, and ensuring compliance with local health codes. Regular grease trap maintenance prevents costly backups and code violations."
        }
      }
    ]
  })} />

  <Footer />
</Layout>
