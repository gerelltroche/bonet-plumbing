---
const year = new Date().getFullYear();
const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<footer class="bg-primary-dark border-t border-white/10">
  <div class="max-w-5xl mx-auto px-4 py-10 text-center">
    <!-- Brand -->
    <div class="flex items-center justify-center gap-2.5 mb-4">
      <svg class="w-6 h-6 text-white/80" viewBox="0 0 100 120" fill="currentColor">
        <path d="M50 5 L90 20 L90 55 C90 80 70 105 50 115 C30 105 10 80 10 55 L10 20 Z" fill="currentColor" opacity="0.2" stroke="currentColor" stroke-width="5"/>
        <path d="M40 55 L55 40 L60 45 L48 72 Z" fill="currentColor" opacity="0.6"/>
        <circle cx="58" cy="38" r="6" fill="none" stroke="currentColor" stroke-width="4" opacity="0.6"/>
      </svg>
      <span class="text-lg font-bold text-white/90">Bonet Plumbing LLC</span>
    </div>

    <!-- Contact -->
    <a href={phone} class="text-white/70 hover:text-white text-sm transition-colors">
      {phoneDisplay}
    </a>
    <span class="text-white/30 mx-2">|</span>
    <span class="text-white/50 text-sm">Mon–Sat 7am–6pm</span>

    <!-- Legal -->
    <p class="text-white/40 text-sm mt-4">
      &copy; {year} Bonet Plumbing LLC
      <span class="mx-2">|</span>
      Licensed & Insured
      <span class="mx-2">|</span>
      Serving Central Florida
    </p>
  </div>
</footer>
