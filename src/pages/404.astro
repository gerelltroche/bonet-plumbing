---
import Layout from "../layouts/Layout.astro";
import StickyNav from "../components/StickyNav.astro";
import Footer from "../components/Footer.astro";

const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<Layout title="Page Not Found | Bonet Plumbing LLC" description="The page you're looking for doesn't exist. Contact Bonet Plumbing for trusted plumbing services in Oviedo, Winter Springs & East Orlando." noindex={true}>
  <StickyNav />
  <main class="bg-white py-24 md:py-32">
    <div class="max-w-xl mx-auto px-4 text-center">
      <p class="text-6xl font-extrabold text-primary mb-4">404</p>
      <h1 class="text-2xl md:text-3xl font-bold text-text mb-4">Page Not Found</h1>
      <p class="text-text-secondary mb-8">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold px-6 py-3 rounded-lg transition-all duration-200"
        >
          Back to Home
        </a>
        <a
          href={phone}
          class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent-light text-white font-bold px-6 py-3 rounded-lg transition-all duration-200"
        >
          Call {phoneDisplay}
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
