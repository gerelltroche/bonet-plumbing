---
interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = "Bonet Plumbing LLC | Trusted Plumbing in Oviedo, Winter Springs & East Orlando",
  description = "Central Florida's trusted plumbing experts. Licensed & insured, same-day service. 15% OFF all repairs & installations. Call 407-734-3968.",
  noindex = false,
} = Astro.props;

const siteUrl = "https://bonetplumbing.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;

import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.jpg`} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Plumber",
      "name": "Bonet Plumbing LLC",
      "description": "Licensed & insured plumbing services in Central Florida. Plumbers in Shining Armor.",
      "url": siteUrl,
      "telephone": "+14077343968",
      "image": `${siteUrl}/logo_with_text.jpeg`,
      "logo": `${siteUrl}/logo_with_text.jpeg`,
      "sameAs": [
        // TODO: Add your actual profile URLs here
        // "https://www.google.com/maps/place/Bonet+Plumbing+LLC",
        // "https://www.facebook.com/bonetplumbing",
        // "https://www.yelp.com/biz/bonet-plumbing-oviedo"
      ],
      "areaServed": [
        { "@type": "City", "name": "Oviedo", "sameAs": "https://en.wikipedia.org/wiki/Oviedo,_Florida" },
        { "@type": "City", "name": "Winter Springs", "sameAs": "https://en.wikipedia.org/wiki/Winter_Springs,_Florida" },
        { "@type": "City", "name": "East Orlando" },
        { "@type": "City", "name": "Chuluota", "sameAs": "https://en.wikipedia.org/wiki/Chuluota,_Florida" },
        { "@type": "City", "name": "Geneva", "sameAs": "https://en.wikipedia.org/wiki/Geneva,_Florida" },
        { "@type": "City", "name": "Casselberry", "sameAs": "https://en.wikipedia.org/wiki/Casselberry,_Florida" },
        { "@type": "City", "name": "Altamonte Springs", "sameAs": "https://en.wikipedia.org/wiki/Altamonte_Springs,_Florida" },
        { "@type": "City", "name": "Longwood", "sameAs": "https://en.wikipedia.org/wiki/Longwood,_Florida" },
        { "@type": "City", "name": "Lake Mary", "sameAs": "https://en.wikipedia.org/wiki/Lake_Mary,_Florida" },
        { "@type": "City", "name": "Sanford", "sameAs": "https://en.wikipedia.org/wiki/Sanford,_Florida" },
        { "@type": "City", "name": "Goldenrod", "sameAs": "https://en.wikipedia.org/wiki/Goldenrod,_Florida" },
        { "@type": "City", "name": "Fern Park", "sameAs": "https://en.wikipedia.org/wiki/Fern_Park,_Florida" },
        { "@type": "City", "name": "Alafaya", "sameAs": "https://en.wikipedia.org/wiki/Alafaya,_Florida" },
        { "@type": "City", "name": "Waterford Lakes" },
        { "@type": "City", "name": "Avalon Park" },
        { "@type": "City", "name": "Union Park", "sameAs": "https://en.wikipedia.org/wiki/Union_Park,_Florida" },
        { "@type": "City", "name": "Winter Park", "sameAs": "https://en.wikipedia.org/wiki/Winter_Park,_Florida" },
        { "@type": "City", "name": "Maitland", "sameAs": "https://en.wikipedia.org/wiki/Maitland,_Florida" }
      ],
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "FL",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 28.6700,
        "longitude": -81.2081
      },
      "priceRange": "$$",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "07:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "07:00",
          "closes": "18:00"
        }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Plumbing Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Plumbing Repairs", "url": `${siteUrl}/plumbing-repairs` }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Water Heater Services", "url": `${siteUrl}/water-heater-services` }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Drain Cleaning", "url": `${siteUrl}/drain-cleaning` }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fixture Installation", "url": `${siteUrl}/fixture-installation` }}
        ]
      }
    })} />

  </head>
  <body class="min-h-screen antialiased bg-background text-text">
    <slot />
  </body>
</html>
