---
import Layout from "../layouts/Layout.astro";
import StickyNav from "../components/StickyNav.astro";
import Footer from "../components/Footer.astro";

const phone = "tel:+14077343968";
const phoneDisplay = "407-734-3968";
---

<Layout
  title="Repiping Services | Bonet Plumbing LLC"
  description="Professional repiping services in Central Florida. Whole-home repipes, galvanized & polybutylene pipe replacement. Licensed & insured. Call 407-734-3968."
  breadcrumbs={[
    { name: "Home", url: "https://bonetplumbing.com/" },
    { name: "Repiping" }
  ]}
>
  <StickyNav />
  <main>
    <section class="bg-gradient-to-b from-primary/[0.03] via-white to-white py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-extrabold text-text leading-tight mb-4">
          Repiping Services in Central Florida
        </h1>
        <div class="w-16 h-1 bg-accent rounded-full mb-6"></div>
        <p class="text-lg text-text-secondary mb-8 max-w-2xl">
          Rusty water, low pressure, or constant leaks? If your home has aging galvanized or polybutylene pipes, patching won't cut it forever. We'll replace your old plumbing with modern, long-lasting materials — with upfront pricing and minimal disruption to your daily routine.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Whole-Home Repiping</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Complete replacement of all supply lines with modern PEX or copper piping. Restores full water pressure, eliminates leaks, and gives your plumbing a fresh start that lasts decades.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Galvanized Pipe Replacement</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Galvanized steel pipes corrode from the inside out, causing rusty water and shrinking water pressure over time. We remove them and upgrade to modern materials that won't rust.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Polybutylene Pipe Replacement</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Poly-B pipes (common in Florida homes built 1978–1995) are prone to sudden failure. We replace them before they burst — protecting your home from costly water damage.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-3">Partial Repiping</h2>
            <p class="text-text-secondary text-sm leading-relaxed">Don't need a full repipe? We can target problem areas — replacing damaged sections, upgrading specific runs, or repiping a single bathroom or kitchen.</p>
          </div>
        </div>

        <div class="bg-accent/10 border border-accent/20 rounded-lg p-6 mb-10">
          <p class="font-bold text-text mb-1">Save 15% on Repiping Services</p>
          <p class="text-text-secondary text-sm">Mention this offer when you call. Available for Oviedo, Winter Springs & East Orlando residents.</p>
          <p class="text-text-secondary text-xs mt-2">Florida License #CFC1434246 · Licensed & Insured</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={phone} class="inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Call Now: {phoneDisplay}
          </a>
          <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-lg px-8 py-4 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg">
            Get a Free Estimate
          </a>
        </div>

        <!-- FAQ Section -->
        <div class="mt-16 pt-8 border-t border-border">
          <h2 class="text-2xl font-bold text-text mb-6">Frequently Asked Questions</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-text mb-2">How do I know if my home needs repiping?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Common signs include discolored or rusty water, low water pressure at multiple fixtures, frequent leaks in different areas, and visible corrosion on exposed pipes. If your home was built before 1995 and still has its original plumbing, a free inspection can tell you where things stand.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">How long does a whole-home repipe take?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Most whole-home repipes are completed in 1–3 days depending on the size of the home and accessibility of the pipes. We minimize disruption by working room-by-room and restoring water service as quickly as possible.</p>
            </div>
            <div>
              <h3 class="font-bold text-text mb-2">What pipe materials do you use?</h3>
              <p class="text-text-secondary text-sm leading-relaxed">We primarily use PEX (cross-linked polyethylene) for supply lines — it's flexible, corrosion-resistant, and backed by a long warranty. For specific applications, we also work with copper. We'll recommend the best option for your home and budget.</p>
            </div>
          </div>
        </div>

        <nav class="mt-16 pt-8 border-t border-border" aria-label="Other services">
          <h2 class="text-lg font-bold text-text mb-4">Our Other Services</h2>
          <ul class="flex flex-wrap gap-3">
            <li><a href="/plumbing-repairs" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Plumbing Repairs</a></li>
            <li><a href="/water-heater-services" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Water Heater Services</a></li>
            <li><a href="/drain-cleaning" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Drain Cleaning</a></li>
            <li><a href="/fixture-installation" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Fixture Installation</a></li>
            <li><a href="/light-commercial-plumbing" class="text-accent hover:text-accent-light font-medium text-sm transition-colors">Light Commercial</a></li>
          </ul>
        </nav>
      </div>
    </section>
  </main>

  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I know if my home needs repiping?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Common signs include discolored or rusty water, low water pressure at multiple fixtures, frequent leaks in different areas, and visible corrosion on exposed pipes. If your home was built before 1995 and still has its original plumbing, a free inspection can tell you where things stand."
        }
      },
      {
        "@type": "Question",
        "name": "How long does a whole-home repipe take?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most whole-home repipes are completed in 1–3 days depending on the size of the home and accessibility of the pipes. We minimize disruption by working room-by-room and restoring water service as quickly as possible."
        }
      },
      {
        "@type": "Question",
        "name": "What pipe materials do you use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We primarily use PEX (cross-linked polyethylene) for supply lines — it's flexible, corrosion-resistant, and backed by a long warranty. For specific applications, we also work with copper. We'll recommend the best option for your home and budget."
        }
      }
    ]
  })} />

  <Footer />
</Layout>
